{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a KudiGrid user registered in the fintech application.",
      "type": "object",
      "properties": {
        "password": {
          "type": "string",
          "description": "User password for authentication."
        },
        "depositBalance": {
          "type": "number",
          "description": "The current deposit balance."
        },
        "referralBalance": {
          "type": "number",
          "description": "The current referral commission balance."
        },
        "taskBalance": {
          "type": "number",
          "description": "The current task earnings balance."
        },
        "currentPlan": {
          "type": "string",
          "description": "The active premium membership plan."
        },
        "phone": {
          "type": "string",
          "description": "Registered phone number."
        },
        "referral": {
          "type": "string",
          "description": "Referrer's username."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created."
        }
      },
      "required": ["password", "depositBalance", "referralBalance", "taskBalance", "currentPlan"]
    },
    "Payout": {
      "title": "Payout",
      "description": "Represents a payout/withdrawal record under a user.",
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "description": "Withdrawal amount in Naira."
        },
        "accountNumber": {
          "type": "string",
          "description": "Recipient bank account number."
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp when the withdrawal was requested."
        },
        "status": {
          "type": "string",
          "description": "Status of the payout (e.g. Success)."
        }
      },
      "required": ["amount", "accountNumber", "timestamp", "status"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "Represents a successful deposit made via Flutterwave.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "txRef": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["amount", "transactionId", "txRef", "paymentMethod", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{username}": {
      "schema": "User",
      "description": "Collection of all registered users on KudiGrid, where the document ID is the username."
    },
    "users/{username}/payouts/{payoutId}": {
      "schema": "Payout",
      "description": "Sub-collection under a user storing recent withdrawal payouts."
    },
    "users/{username}/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "Sub-collection under a user storing successful deposit history."
    }
  }
}
