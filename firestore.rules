rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for KudiGrid User document
    match /users/{username} {
      allow read, write: if true;

      // Subcollection for payout withdrawals
      match /payouts/{payoutId} {
        allow read, write: if true;
      }

      // Subcollection for referral transactions
      match /referralTransactions/{txId} {
        allow read, write: if true;
      }

      // Subcollection for completed tasks
      match /completedTasks/{taskId} {
        allow read, write: if true;
      }
    }

    // Rules for root withdrawals collection
    match /withdrawals/{withdrawalId} {
      allow read, write: if true;
    }
  }
}
